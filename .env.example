# Site
# Local: http://localhost:3000
# Production (Vercel): https://elfinsahin.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact form (Resend)
# Get your API key at https://resend.com
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@eflin.studio
CONTACT_FROM_EMAIL=Eflin Portfolio <onboarding@resend.dev>

# Analytics (optional)
# Set to true to enable Vercel Analytics
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# Admin panel — required for /admin (development and production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Ae080919

# Vercel Blob — persistent content storage in production
# Create a Blob store in Vercel Dashboard → Storage, connect to this project.
# Vercel adds BLOB_READ_WRITE_TOKEN automatically when the store is linked.
BLOB_READ_WRITE_TOKEN=

# Legacy: allow writing content/site-content.json from /admin in production (optional)
# Prefer BLOB_READ_WRITE_TOKEN instead. Default: file write only in development.
ADMIN_ENABLE_FILE_WRITE=false
